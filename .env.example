# Copy to .env (which is gitignored) and fill in your own values.
# Used by bench/runner/* on testnets only. NEVER use on mainnet.

# Generate a fresh BIP39 mnemonic with: python -c "from mnemonic import Mnemonic; print(Mnemonic('english').generate(strength=256))"
BENCH_SEED="<24-word mnemonic here>"

# Address #0 derived from BENCH_SEED at m/44'/60'/0'/0/0.
# Used to verify funding before running web3 fixtures.
BENCH_ADDRESS_0="0x..."

# MetaMask password (also re-used by qa_agent's existing TEST_PASSWORD).
BENCH_PASSWORD="Testpassword1!"
